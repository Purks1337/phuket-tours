---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<section class="mb-10">
  <div class="border-b-2 border-black mb-6 pb-2">
    <h2 class="text-2xl font-black uppercase tracking-wider">{title}</h2>
  </div>
  <div class="flex flex-col gap-3">
    <slot />
  </div>
</section>