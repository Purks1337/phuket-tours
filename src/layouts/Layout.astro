---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { 
    title, 
    description = "Лучшие экскурсии на Пхукете — морские прогулки, джунгли, экстрим. Бронируйте без предоплаты за 5 минут!" 
} = Astro.props;
---

<!doctype html>
<html lang="ru" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
        <link rel="sitemap" href="/sitemap-index.xml" />
	</head>
	<body class="bg-slate-50 text-gray-900 font-sans flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow w-full max-w-[1200px] mx-auto px-4 md:px-8 py-8 md:py-12">
			<slot />
		</main>
		<Footer />
	</body>
</html>