---
import Layout from '../layouts/Layout.astro';
import CategorySection from '../components/CategorySection.astro';
import TourRow from '../components/TourRow.astro';
import { getCollection } from 'astro:content';

// Запрашиваем все экскурсии из коллекции, которую мы настроили в Шаге 3
const allExcursions = await getCollection('excursions');

// Группируем экскурсии по категориям. 
// Получится объект вида: { "Морские":[тур1, тур2], "Сухопутные": [тур3] }
const groupedExcursions = allExcursions.reduce((acc, tour) => {
  const category = tour.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(tour);
  return acc;
}, {} as Record<string, typeof allExcursions>);
---

<Layout title="Каталог экскурсий на Пхукете | MyThai Guru">
  <div class="mb-10 text-center md:text-left">
    <h1 class="text-4xl font-black uppercase tracking-wider mb-4">
      Экскурсии <span class="text-blue-600">Пхукет</span>
    </h1>
    <p class="text-gray-600">
      Выберите лучшую экскурсию по самой выгодной цене. Бронирование онлайн через Telegram без предоплаты.
    </p>
  </div>

  <div class="flex flex-col gap-8">
    {Object.entries(groupedExcursions).map(([category, tours]) => (
      <CategorySection title={category}>
        {tours.map((tour) => (
          <TourRow 
            id={tour.id} 
            title={tour.data.title} 
            priceAdult={tour.data.priceAdult} 
            badges={tour.data.badges} 
          />
        ))}
      </CategorySection>
    ))}
  </div>
</Layout>