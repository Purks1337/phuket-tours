---
import Layout from '../../layouts/Layout.astro';
import BookingForm from '../../components/BookingForm.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const excursions = await getCollection('excursions');
  return excursions.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | MyThai Guru`}>
  <div class="mb-6">
    <a href="/" class="text-blue-500 text-sm font-medium hover:underline inline-flex items-center gap-1">
      <span class="text-lg leading-none">←</span> Назад к списку
    </a>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10 mb-10">
    <!-- Бейджи -->
    {post.data.badges && post.data.badges.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.badges.map((badge) => (
          <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">
            {badge}
          </span>
        ))}
      </div>
    )}
    
    <!-- Заголовок -->
    <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-6 uppercase tracking-wider">
      {post.data.title}
    </h1>

    <!-- Блок с ценой -->
    <div class="bg-[#f7f7f7] rounded-xl p-4 md:p-6 mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border border-gray-200">
      <div>
        <span class="block text-[11px] text-gray-500 uppercase tracking-wider font-semibold mb-1">Стоимость (Взрослый)</span>
        <span class="text-3xl font-black text-blue-600">{post.data.priceAdult} ฿</span>
      </div>
      <a href="#booking-form" class="bg-blue-600 text-white px-8 py-4 rounded-full font-bold hover:bg-blue-700 transition w-full md:w-auto text-center">
        Забронировать
      </a>
    </div>

    <!-- Текст из Markdown -->
    <div class="markdown-content text-gray-700 leading-relaxed">
      <Content />
    </div>
    
    <!-- Форма бронирования -->
    <div id="booking-form" class="mt-12 pt-10 border-t border-gray-200">
      <h2 class="text-2xl font-black uppercase tracking-wider mb-2 text-center md:text-left">Бронирование</h2>
      <p class="text-gray-500 mb-8 text-center md:text-left">
        Оставьте заявку, и мы свяжемся с вами в Telegram для подтверждения деталей.
      </p>
      
      <div class="bg-white p-6 md:p-8 rounded-xl border border-gray-200 shadow-sm">
        <BookingForm tourTitle={post.data.title} />
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .markdown-content p { margin-bottom: 1.25rem; }
  .markdown-content h2 { font-size: 1.5rem; font-weight: 900; margin-top: 2rem; margin-bottom: 1rem; text-transform: uppercase; color: #111827; }
  .markdown-content h3 { font-size: 1.25rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.75rem; color: #1f2937; }
  .markdown-content ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .markdown-content li { margin-bottom: 0.5rem; }
</style>